# name: test/sql/holdings.test
# description: ishares.holdings base table — fund_ticker partition (pushdown) + AT time travel.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'ishares' AS ish (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='ish.main';

# --- Schema: DESCRIBE binds only (no network). `holdings` is a base TABLE. ---

query T
SELECT string_agg(column_name, ',') FROM (DESCRIBE SELECT * FROM ish.holdings WHERE fund_ticker = 'IVV');
----
fund_ticker,as_of_date,ticker,name,sector,asset_class,country,currency,exchange,isin,cusip,sedol,weight_percent,market_value,notional_value,units_held,price,accrual_date,coupon_percent,maturity_date,duration,ytm_percent,par_value,market_currency

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM ish.holdings WHERE fund_ticker = 'IVV') WHERE column_name = 'as_of_date';
----
DATE

# --- Live invariants (hit iShares). ---

# Partition pushdown: WHERE fund_ticker = 'IVV' fetches that fund's holdings, weight-descending.
query I
SELECT (count(*) > 100 AND max(weight_percent) > 0 AND bool_and(fund_ticker = 'IVV'))::INT
FROM ish.holdings WHERE fund_ticker = 'IVV';
----
1

# Time travel: AT (TIMESTAMP => DATE) returns that day's holdings, tagged with that date.
query I
SELECT (count(*) > 100 AND min(as_of_date) = DATE '2025-01-02' AND max(as_of_date) = DATE '2025-01-02')::INT
FROM ish.holdings AT (TIMESTAMP => DATE '2025-01-02') WHERE fund_ticker = 'IVV';
----
1

# Multiple partitions at once: fund_ticker IN (...) fans out to two funds.
query I
SELECT (count(DISTINCT fund_ticker) = 2)::INT FROM ish.holdings WHERE fund_ticker IN ('IVV', 'AGG');
----
1

# An unfiltered scan is now allowed — it streams EVERY fund's holdings (one partition per fund).
# LIMIT short-circuits the stream after the first partition, so this stays cheap (no 530-fund fan-out).
query I
SELECT (count(*) >= 1)::INT FROM (SELECT * FROM ish.holdings LIMIT 5);
----
1

# The backing scan function also works directly (pushdown, no time travel). It shares the table's
# name; call it WITH parentheses to reach the function rather than the `holdings` table.
query I
SELECT (count(*) > 100)::INT FROM ish.holdings() WHERE fund_ticker = 'IVV';
----
1
