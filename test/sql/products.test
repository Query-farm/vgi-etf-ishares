# name: test/sql/products.test
# description: ishares.products — base table: typed schema (network-free) + live catalog invariants.
# group: [sql]

require-env VGI_TEST_WORKER

statement ok
ATTACH 'ishares' AS ish (TYPE vgi, LOCATION '${VGI_TEST_WORKER}');

statement ok
SET search_path='ish.main';

# --- Schema: DESCRIBE binds only (no network), so these are fully deterministic. ---
# `products` is a base TABLE — query it with no parentheses.

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM ish.products) WHERE column_name = 'ticker';
----
VARCHAR

# The internal iShares portfolio_id is NOT exposed as a column (funds are keyed by ticker).
query I
SELECT count(*)::INT FROM (DESCRIBE SELECT * FROM ish.products) WHERE column_name = 'portfolio_id';
----
0

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM ish.products) WHERE column_name = 'net_assets';
----
DOUBLE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM ish.products) WHERE column_name = 'inception_date';
----
DATE

query T
SELECT column_type FROM (DESCRIBE SELECT * FROM ish.products) WHERE column_name = 'expense_ratio_percent';
----
DOUBLE

# --- Live invariants: these hit iShares. Assert shape, not exact (moving) values. ---

# The catalog has many funds (all product types; filter with WHERE).
query I
SELECT (count(*) > 50)::INT FROM ish.products;
----
1

# IVV (iShares Core S&P 500 ETF) is present with a non-negative expense ratio — via a WHERE.
query I
SELECT (count(*) = 1)::INT FROM ish.products WHERE ticker = 'IVV' AND expense_ratio_percent >= 0;
----
1

# The table returns every product type — mutual funds are no longer hidden behind a default.
query I
SELECT (count(DISTINCT product_view) >= 1)::INT FROM ish.products;
----
1
